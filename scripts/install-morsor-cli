#!/usr/bin/env bash
set -euo pipefail

# Installs the Python morsor-cli into a writable directory.
# Usage: ./scripts/install-morsor-cli /path/to/writable/bin-dir

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
if [[ $# -ne 1 ]]; then
  echo "Usage: $0 <writable-install-dir>" >&2
  exit 1
fi
BIN_DIR="$1"
SRC="${ROOT}/tools/morsor-cli/morsor_cli.py"
WRAPPER_DST="${BIN_DIR}/morsor-cli"

if [[ ! -f "${SRC}" ]]; then
  echo "ERROR: CLI not found: ${SRC}" >&2
  exit 1
fi

if [[ ! -d "${BIN_DIR}" ]]; then
  echo "ERROR: destination directory does not exist: ${BIN_DIR}" >&2
  exit 1
fi

if [[ ! -w "${BIN_DIR}" ]]; then
  echo "ERROR: ${BIN_DIR} is not writable. Re-run with sudo." >&2
  exit 1
fi

echo "Installing morsor-cli to ${WRAPPER_DST}..."
install -m 0755 "${SRC}" "${WRAPPER_DST}"

echo "Installed:"
echo "  ${WRAPPER_DST}"
echo "Requires: python3 on PATH"
