#!/usr/bin/env bash
set -euo pipefail

# Builds morsor-api-cli and installs both the wrapper and jar into the provided directory.
# Usage: ./scripts/install-cli /path/to/writable/bin-dir

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
if [[ $# -ne 1 ]]; then
  echo "Usage: $0 <writable-install-dir>" >&2
  exit 1
fi
BIN_DIR="$1"
WRAPPER_DST="${BIN_DIR}/morsor-cli"
JAR_NAME="morsor-api-cli-0.0.1-SNAPSHOT.jar"
JAR_SRC="${ROOT}/tools/morsor-api-cli/build/libs/${JAR_NAME}"
JAR_DST="${BIN_DIR}/${JAR_NAME}"

cd "${ROOT}"

echo "Building morsor-api-cli jar..."
./gradlew :morsor-api-cli:jar -q

if [[ ! -f "${JAR_SRC}" ]]; then
  echo "ERROR: expected jar not found: ${JAR_SRC}" >&2
  exit 1
fi

if [[ ! -d "${BIN_DIR}" ]]; then
  echo "ERROR: destination directory does not exist: ${BIN_DIR}" >&2
  exit 1
fi

if [[ ! -w "${BIN_DIR}" ]]; then
  echo "ERROR: ${BIN_DIR} is not writable. Re-run with sudo." >&2
  exit 1
fi

echo "Installing jar to ${JAR_DST}..."
install -m 0644 "${JAR_SRC}" "${JAR_DST}"

echo "Installing wrapper to ${WRAPPER_DST}..."
cat > "${WRAPPER_DST}" <<'EOF'
#!/usr/bin/env bash
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
exec java -jar "${SCRIPT_DIR}/morsor-api-cli-0.0.1-SNAPSHOT.jar" "$@"
EOF
chmod 0755 "${WRAPPER_DST}"

echo "Installed:"
echo "  ${WRAPPER_DST}"
echo "  ${JAR_DST}"
