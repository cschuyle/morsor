#!/usr/bin/env python3
"""
HTTP CLI for the Morsor backend (stdlib only: no pip install required).
"""
from __future__ import annotations

import getpass
import hashlib
import json
import os
import re
import sys
import time
import urllib.error
import urllib.parse
import urllib.request
from http.cookiejar import CookieJar
from pathlib import Path
from typing import Any
from urllib.error import HTTPError, URLError

DEV_DEFAULT_TOKEN = "dev-token"
MAX_LOCAL_TROVE_ITEMS = 50_000
TOKEN_JSON = re.compile(r'"token"\s*:\s*"([^"]+)"')
TROVE_ROW_JSON = re.compile(
    r'"id"\s*:\s*"((?:\\.|[^"\\])*)".*?"name"\s*:\s*"((?:\\.|[^"\\])*)".*?"count"\s*:\s*(\d+)',
    re.DOTALL,
)


def die(msg: str, code: int = 2) -> None:
    print(f"morsor-cli: {msg}", file=sys.stderr)
    sys.exit(code)


def _server_unreachable(base: str, e: URLError) -> str:
    reason = str(e.reason) if hasattr(e, "reason") and e.reason else str(e)
    return f"Cannot reach server at {strip_trailing_slash(base)}: {reason}"


def strip_trailing_slash(s: str) -> str:
    return s[:-1] if s.endswith("/") and len(s) > 1 else s


def is_likely_local_dev_base(base: str) -> bool:
    try:
        p = urllib.parse.urlparse(base)
        h = (p.hostname or "").lower()
        return h in ("localhost", "127.0.0.1")
    except Exception:
        return False


def shell_single_quoted(s: str) -> str:
    return "'" + s.replace("'", "'\\''") + "'"


def normalize_output_mode(raw: str) -> str:
    v = (raw or "").strip().lower()
    if v in ("json", "j"):
        return "json"
    if v in ("text", "txt", "t"):
        return "text"
    die(f"invalid output mode: {raw} (expected json/j or text/txt/t)")


def map_shorthand_key(key: str) -> str:
    m = {
        "q": "query",
        "p": "primaryTrove",
        "primary": "primaryTrove",
        "c": "compareTrove",
        "compare": "compareTrove",
        "P": "page",
        "page": "page",
        "S": "size",
        "pageSize": "size",
        "size": "size",
        "s": "sortBy",
        "sortBy": "sortBy",
        "d": "sortDir",
        "sortDir": "sortDir",
        "t": "trove",
        "trove": "trove",
    }
    return m.get(key, key)


def add_shorthand_param(params: list[tuple[str, str]], key: str, value: str) -> None:
    k = map_shorthand_key(key)
    if k == "trove":
        for part in value.split(","):
            t = part.strip()
            if t:
                params.append(("trove", t))
        return
    params.append((k, value))


def add_or_append_query(params: list[tuple[str, str]], value: str) -> None:
    for j, (pk, pv) in enumerate(params):
        if pk == "query":
            params[j] = ("query", pv + " " + value)
            return
    params.append(("query", value))


def encode_query(params: list[tuple[str, str]]) -> str:
    if not params:
        return ""
    parts = []
    for k, v in params:
        parts.append(
            urllib.parse.quote(k, safe="")
            + "="
            + urllib.parse.quote(v, safe="")
        )
    return "&".join(parts)


def parse_shorthand_query(args: list[str], start_idx: int) -> str:
    params: list[tuple[str, str]] = []
    naked: list[str] = []
    i = start_idx
    while i < len(args):
        a = args[i]
        if a == "--man":
            print_usage()
            sys.exit(0)
        if a in ("--help", "-h", "help"):
            print_summary_usage()
            sys.exit(0)
        if a == "--":
            i += 1
            while i < len(args):
                raw = args[i]
                i += 1
                if "=" not in raw or raw.index("=") <= 0:
                    die(f"raw query items after -- must be key=value, got: {raw}")
                eq = raw.index("=")
                params.append((raw[:eq], raw[eq + 1 :]))
            break
        if a.startswith("--"):
            nv = a[2:]
            if not nv:
                die(f"empty parameter name: {a}")
            if "=" in nv:
                eq = nv.index("=")
                key, value = nv[:eq], nv[eq + 1 :]
            else:
                key = nv
                i += 1
                if i >= len(args):
                    die(f"missing value for --{key}")
                value = args[i]
            add_shorthand_param(params, key, value)
        elif a.startswith("-") and len(a) > 1:
            nv = a[1:]
            if "=" in nv:
                eq = nv.index("=")
                key, value = nv[:eq], nv[eq + 1 :]
            else:
                key = nv
                i += 1
                if i >= len(args):
                    die(f"missing value for -{key}")
                value = args[i]
            add_shorthand_param(params, key, value)
        else:
            naked.append(a)
        i += 1
    if naked:
        add_or_append_query(params, " ".join(naked))
    return encode_query(params)


def resolve_action(token: str) -> tuple[str, str] | None:
    t = token.lower().rstrip(":")
    actions = {
        "troves": ("GET", "/api/troves"),
        "status": ("GET", "/api/status"),
        "search": ("GET", "/api/search"),
        "dups": ("GET", "/api/search/duplicates"),
        "duplicates": ("GET", "/api/search/duplicates"),
        "dupliicates": ("GET", "/api/search/duplicates"),
        "unique": ("GET", "/api/search/uniques"),
        "uniques": ("GET", "/api/search/uniques"),
    }
    if t in actions:
        return actions[t]
    return None


def is_http_method(s: str) -> bool:
    return s.upper() in ("GET", "POST", "HEAD")


def is_local_trove_action(token: str) -> bool:
    t = token.lower().rstrip(":")
    return t in ("local-trove", "register-local-dir")


def is_local_command(token: str) -> bool:
    return token.lower().rstrip(":") == "local"


def pad_right(s: str, n: int) -> str:
    return s if len(s) >= n else s + " " * (n - len(s))


def print_search_text(json_str: str) -> None:
    if not json_str or not json_str.strip():
        return
    try:
        root = json.loads(json_str)
    except json.JSONDecodeError:
        return
    results = root.get("results")
    if not isinstance(results, list):
        return
    rows: list[tuple[float, str, str]] = []
    for node in results:
        if not isinstance(node, dict):
            continue
        payload = node["result"] if isinstance(node.get("result"), dict) else node
        title = _json_text(payload.get("title"))
        trove_id = _json_text(payload.get("troveId")) or ""
        score = 0.0
        sn = node.get("score")
        if isinstance(sn, (int, float)):
            score = float(sn)
        rows.append((score, trove_id, title or ""))
    if not rows:
        return
    max_trove = max(len(r[1]) for r in rows)
    for score, trove_id, title in rows:
        print(f"{score:.2f}\t{pad_right(trove_id, max_trove)}\t{title}")


def _json_text(v: Any) -> str | None:
    if v is None:
        return None
    if isinstance(v, str):
        return v
    if isinstance(v, (int, float, bool)):
        return str(v)
    return json.dumps(v)


def print_troves_text(json_str: str) -> None:
    if not json_str or not json_str.strip():
        return
    try:
        arr = json.loads(json_str)
    except json.JSONDecodeError:
        m = TROVE_ROW_JSON.finditer(json_str)
        rows = []
        for x in m:
            rows.append((x.group(1), x.group(3), x.group(2), ""))
        if not rows:
            return
    else:
        if not isinstance(arr, list):
            return
        rows = []
        for o in arr:
            if not isinstance(o, dict):
                continue
            tag = "[local]" if o.get("cliCreated") else ""
            rows.append((str(o.get("id", "")), str(o.get("count", "")), str(o.get("name", "")), tag))
    max_id = max(len(r[0]) for r in rows) if rows else 0
    max_c = max(len(r[1]) for r in rows) if rows else 0
    for tid, cnt, name, tag in rows:
        suffix = f"\t{tag}" if tag else ""
        print(f"{pad_right(tid, max_id)}\t{pad_right(cnt, max_c)}\t{name}{suffix}")


def print_duplicates_text(json_str: str) -> None:
    if not json_str or not json_str.strip():
        return
    try:
        root = json.loads(json_str)
    except json.JSONDecodeError:
        return
    rows = root.get("rows")
    if not isinstance(rows, list):
        return
    for row in rows:
        if not isinstance(row, dict):
            continue
        prim = row.get("primary")
        title = ""
        if isinstance(prim, dict):
            title = str(prim.get("title", ""))
        matches = row.get("matches") or []
        n = len(matches) if isinstance(matches, list) else 0
        print(f"{title}\tmatches={n}")


def print_uniques_text(json_str: str) -> None:
    if not json_str or not json_str.strip():
        return
    try:
        root = json.loads(json_str)
    except json.JSONDecodeError:
        return
    results = root.get("results")
    if not isinstance(results, list):
        return
    for u in results:
        if not isinstance(u, dict):
            continue
        item = u.get("item")
        if isinstance(item, dict):
            title = str(item.get("title", ""))
        else:
            title = ""
        sc = u.get("score", 0)
        print(f"{float(sc):.2f}\t{title}")


def print_text_for_path(json_str: str, path: str) -> None:
    if "/api/troves" == path:
        print_troves_text(json_str)
    elif "/duplicates" in path:
        print_duplicates_text(json_str)
    elif "/uniques" in path:
        print_uniques_text(json_str)
    else:
        print_search_text(json_str)


def local_trove_err(msg: str) -> None:
    print(f"morsor-cli: local-trove: {msg}", file=sys.stderr)


def json_body_preview(s: str, max_chars: int) -> str:
    if s is None:
        return "(null)"
    if len(s) <= max_chars:
        return s
    return s[:max_chars] + f"\n… ({len(s)} chars total)"


def run_local_trove(
    base: str,
    bearer: str | None,
    extra_headers: list[str],
    show_headers: bool,
    debug: bool,
    output_mode: str,
    positional: list[str],
    preparsed_name_override: str | None = None,
) -> None:
    idx = 1
    input_file: Path | None = None
    name_override: str | None = preparsed_name_override
    while idx < len(positional):
        token = positional[idx]
        if token.startswith("--name="):
            value = token.split("=", 1)[1].strip()
            if not value:
                die("local-trove: --name requires a non-empty value")
            if name_override is not None:
                die("local-trove: --name was provided more than once")
            name_override = value
            idx += 1
            continue
        if token == "--name":
            idx += 1
            if idx >= len(positional):
                die("local-trove: --name requires a value")
            value = positional[idx].strip()
            if not value:
                die("local-trove: --name requires a non-empty value")
            if name_override is not None:
                die("local-trove: --name was provided more than once")
            name_override = value
            idx += 1
            continue
        if token.startswith("-"):
            die(f"unknown option for local-trove: {token}")
        if input_file is not None:
            die("local-trove: unexpected extra arguments (expected at most one filename)")
        input_file = Path(token).resolve()
        idx += 1
    if input_file is not None:
        if not input_file.is_file():
            die(f"not a file: {input_file}")
        lines = input_file.read_text(encoding="utf-8", errors="replace").splitlines()
        display_name = str(input_file)
        input_label = f"file {input_file}"
        stdin_id_prefix = None
    else:
        lines = sys.stdin.read().splitlines()
        ts = int(time.time())
        display_name = f"stdin-{ts}"
        input_label = "stdin"
        stdin_id_prefix = f"local-{ts}"

    if name_override is not None:
        display_name = name_override

    titles = [line.strip() for line in lines if line.strip()]
    if not titles:
        die("local-trove: no non-empty item titles were provided")
    if len(titles) > MAX_LOCAL_TROVE_ITEMS:
        die(f"too many items (max {MAX_LOCAL_TROVE_ITEMS}): {len(titles)}")

    items = []
    for i, title in enumerate(titles, start=1):
        item_id = str(i) if stdin_id_prefix is None else f"{stdin_id_prefix}-{i}"
        items.append(
            {
                "id": item_id,
                "title": title,
                "files": [],
            }
        )
    body_obj = {"displayName": display_name, "items": items, "cliCreated": True}
    body_bytes = json.dumps(body_obj).encode("utf-8")
    token = bearer
    if (not token or not token.strip()) and is_likely_local_dev_base(base):
        token = DEV_DEFAULT_TOKEN
    url = strip_trailing_slash(base) + "/api/ephemeral-troves"
    local_trove_err(f"input {input_label}")
    local_trove_err(f"items {len(titles)}, JSON payload {len(body_bytes)} bytes")
    local_trove_err(f"POST {url}")
    if debug:
        sample = ", ".join(titles[:10])
        if len(titles) > 10:
            sample += " …"
        local_trove_err(f"[verbose] first item titles: {sample}")
        local_trove_err(f"[verbose] displayName (trove label) {display_name}")
        local_trove_err(
            "[verbose] JSON body preview (first 800 chars):\n"
            + json_body_preview(json.dumps(body_obj), 800)
        )
    headers = {"Content-Type": "application/json"}
    if token and token.strip():
        headers["Authorization"] = "Bearer " + token.strip()
    for h in extra_headers:
        if ":" not in h or h.index(":") <= 0:
            die(f"header must be Name: value, got: {h}")
        name, value = h.split(":", 1)
        headers[name.strip()] = value.strip()
    req = urllib.request.Request(url, data=body_bytes, method="POST", headers=headers)
    if debug:
        print("[debug] request: POST " + url, file=sys.stderr)
        for k, v in headers.items():
            if k.lower() == "authorization":
                print(f"[debug] {k}: <redacted>", file=sys.stderr)
            else:
                print(f"[debug] {k}: {v}", file=sys.stderr)
    try:
        with urllib.request.urlopen(req, timeout=600) as resp:
            raw = resp.read().decode("utf-8", errors="replace")
            code = resp.status
            if debug:
                print(f"[debug] response: {code} {resp.url}", file=sys.stderr)
            if show_headers:
                print(f"{code} {resp.url}")
                for hk, hv in resp.headers.items():
                    print(f"{hk}: {hv}")
                print()
            _finish_local_trove_response(code, raw, output_mode, debug, dict(resp.headers))
    except HTTPError as e:
        raw = e.read().decode("utf-8", errors="replace") if e.fp else ""
        code = e.code
        local_trove_err(f"HTTP {code}, response body {len(raw)} chars")
        if 300 <= code < 400:
            loc = e.headers.get("Location") if e.headers else None
            if loc:
                local_trove_err(
                    f"redirect Location: {loc} (urllib may not follow POST redirects; often /login)"
                )
        if code in (401, 403):
            local_trove_err(
                "auth failed — use -t/--token (or run against localhost for default dev token)"
            )
        if raw:
            local_trove_err("error response body:\n" + json_body_preview(raw, 4096))
        if output_mode == "json":
            print(raw)
        sys.exit(1)
    except URLError as e:
        die(_server_unreachable(base, e))


def _finish_local_trove_response(
    code: int, raw: str, output_mode: str, debug: bool, resp_headers: dict[str, str]
) -> None:
    local_trove_err(f"HTTP {code}, response body {len(raw)} chars")
    if 300 <= code < 400:
        loc = resp_headers.get("Location")
        if loc:
            local_trove_err(
                f"redirect Location: {loc} (POST redirects often mean auth/CSRF; check server)"
            )
    if code in (401, 403):
        local_trove_err(
            "auth failed — use -t/--token (or run against localhost for default dev token)"
        )
    if debug and raw.strip():
        local_trove_err(
            "[verbose] response body preview (first 800 chars):\n" + json_body_preview(raw, 800)
        )
    if code >= 400 and raw.strip():
        local_trove_err("error response body:\n" + json_body_preview(raw, 4096))
    if output_mode == "text":
        print_ephemeral_register_text(raw, debug)
    else:
        sys.stdout.write(raw)
        if raw and not raw.endswith("\n"):
            print()
    if code >= 400:
        sys.exit(1)


def print_ephemeral_register_text(json_str: str, debug: bool) -> None:
    if not json_str or not json_str.strip():
        local_trove_err(
            "success path but response body is empty — check server logs; nothing printed on stdout"
        )
        return
    try:
        o = json.loads(json_str)
        tid = o.get("troveId")
        name = o.get("displayName")
        cnt = o.get("count")
        if tid is not None and name is not None and cnt is not None:
            if debug:
                local_trove_err("[verbose] parsed troveId/displayName/count from JSON ok")
            print(f"troveId\t{tid}")
            print(f"name\t{name}")
            print(f"count\t{cnt}")
            return
    except json.JSONDecodeError:
        pass
    local_trove_err(
        "could not parse troveId + displayName + count from JSON; raw body on stdout"
    )
    print(json_str.rstrip() + ("\n" if json_str and not json_str.endswith("\n") else ""))


def run_login(base: str) -> None:
    user = input("Username: ").strip()
    pw = getpass.getpass("Password: ")
    if not user or not pw:
        die("username and password are required")
    jar = CookieJar()
    opener = urllib.request.build_opener(urllib.request.HTTPCookieProcessor(jar))
    try:
        _run_login_inner(base, user, pw, jar, opener)
    except URLError as e:
        die(_server_unreachable(base, e))


def _run_login_inner(base: str, user: str, pw: str, jar: CookieJar, opener: Any) -> None:

    def open_req(r: urllib.request.Request) -> Any:
        return opener.open(r, timeout=120)

    base_u = strip_trailing_slash(base)
    open_req(urllib.request.Request(base_u + "/api/auth/csrf-prime", method="GET"))
    xsrf = None
    for c in jar:
        if c.name.upper() == "XSRF-TOKEN":
            xsrf = c.value
            break
    if not xsrf:
        die("missing XSRF-TOKEN cookie after CSRF prime; is the server reachable?")
    form = urllib.parse.urlencode({"username": user, "password": pw}).encode("utf-8")
    login_req = urllib.request.Request(
        base_u + "/login",
        data=form,
        method="POST",
        headers={
            "Content-Type": "application/x-www-form-urlencoded",
            "X-XSRF-TOKEN": xsrf,
        },
    )
    try:
        open_req(login_req)
    except HTTPError as e:
        if e.code in (401, 403):
            open_req(urllib.request.Request(base_u + "/api/auth/csrf-prime", method="GET"))
            for c in jar:
                if c.name.upper() == "XSRF-TOKEN":
                    xsrf = c.value
                    break
            login_req = urllib.request.Request(
                base_u + "/login",
                data=form,
                method="POST",
                headers={
                    "Content-Type": "application/x-www-form-urlencoded",
                    "X-XSRF-TOKEN": xsrf,
                },
            )
            try:
                open_req(login_req)
            except HTTPError as e2:
                if e2.code in (401, 403):
                    die("login failed: invalid username or password")
                raise
        else:
            raise
    sess = open_req(urllib.request.Request(base_u + "/api/auth/session", method="GET"))
    sb = sess.read().decode("utf-8", errors="replace")
    if '"authenticated":true' not in sb and '"authenticated": true' not in sb:
        die("login failed: session not authenticated (check credentials and server)")
    tok_req = urllib.request.Request(
        base_u + "/api/tokens",
        data=b"{}",
        method="POST",
        headers={"Content-Type": "application/json"},
    )
    try:
        tr = open_req(tok_req)
    except HTTPError as e:
        die(f"token creation failed: HTTP {e.code} {e.read().decode(errors='replace')}")
    tb = tr.read().decode("utf-8", errors="replace")
    m = TOKEN_JSON.search(tb)
    tok = m.group(1) if m else None
    if not tok:
        die("token creation failed: no token in response")
    print("export MORSOR_CLI_TOKEN=" + shell_single_quoted(tok))


def http_request(
    base: str,
    method: str,
    path: str,
    query: str,
    bearer: str | None,
    extra_headers: list[str],
    body_file: str | None,
    show_headers: bool,
    debug: bool,
    output_mode: str,
) -> None:
    token = bearer
    if (not token or not token.strip()) and is_likely_local_dev_base(base):
        token = DEV_DEFAULT_TOKEN
    url = strip_trailing_slash(base) + path
    if query:
        url += "?" + query
    data = None
    headers: dict[str, str] = {}
    if method == "POST" and body_file:
        data = Path(body_file).read_bytes()
        if not any(h.lower().startswith("content-type:") for h in extra_headers):
            headers["Content-Type"] = "application/json"
    if token and token.strip():
        headers["Authorization"] = "Bearer " + token.strip()
    for h in extra_headers:
        if ":" not in h or h.index(":") <= 0:
            die(f"header must be Name: value, got: {h}")
        name, value = h.split(":", 1)
        headers[name.strip()] = value.strip()
    req = urllib.request.Request(url, data=data, method=method, headers=headers)
    if debug:
        print(f"[debug] request: {method} {url}", file=sys.stderr)
        for k, v in headers.items():
            if k.lower() == "authorization":
                print(f"[debug] {k}: <redacted>", file=sys.stderr)
            else:
                print(f"[debug] {k}: {v}", file=sys.stderr)
    try:
        with urllib.request.urlopen(req, timeout=600) as resp:
            raw = resp.read().decode("utf-8", errors="replace")
            if debug:
                print(f"[debug] response: {resp.status} {resp.url}", file=sys.stderr)
            if show_headers:
                print(f"{resp.status} {resp.url}")
                for hk, hv in resp.headers.items():
                    print(f"{hk}: {hv}")
                print()
            elif debug:
                print(f"{resp.status} {resp.url}", file=sys.stderr)
            if output_mode == "text":
                print_text_for_path(raw, path)
            else:
                sys.stdout.write(raw)
                if raw and not raw.endswith("\n"):
                    print()
            if resp.status >= 400:
                sys.exit(1)
    except HTTPError as e:
        raw = e.read().decode("utf-8", errors="replace") if e.fp else ""
        print(f"morsor-cli: HTTP {e.code} {url}", file=sys.stderr)
        if debug:
            print(f"[debug] response: {e.code}", file=sys.stderr)
        if show_headers and e.headers:
            print(f"{e.code}")
            for hk, hv in e.headers.items():
                print(f"{hk}: {hv}")
            print()
        if output_mode == "json":
            sys.stdout.write(raw)
        sys.exit(1)
    except URLError as e:
        die(_server_unreachable(base, e))


# ──────────────────────────────────────────────────────────────────────────────
# local init / local refresh
# ──────────────────────────────────────────────────────────────────────────────

def _morsor_properties_file() -> str:
    v = os.environ.get("MORSOR_PROPERTIES_FILE", "").strip()
    if not v:
        die("MORSOR_PROPERTIES_FILE is not set — point it to your morsor config YAML or JSON file")
    return v


def _load_morsor_properties(props_file: str) -> dict:
    p = Path(props_file)
    if not p.is_file():
        die(f"MORSOR_PROPERTIES_FILE not found: {p}")
    content = p.read_text(encoding="utf-8")
    # JSON if extension is .json or content starts with '{'
    if p.suffix.lower() == ".json" or content.lstrip().startswith("{"):
        try:
            return json.loads(content)
        except json.JSONDecodeError as e:
            die(f"Failed to parse {p} as JSON: {e}")
    # YAML: optional PyYAML
    try:
        import yaml  # type: ignore
        result = yaml.safe_load(content)
        if not isinstance(result, dict):
            die(f"Expected a YAML mapping at the top level in {p}")
        return result
    except ImportError:
        die(
            f"{p} appears to be YAML but PyYAML is not installed.\n"
            "Install it with: pip install pyyaml\n"
            "Or convert the file to JSON format."
        )
    except Exception as e:
        die(f"Failed to parse {p} as YAML: {e}")


def _get_sisters(data: dict, props_file: str) -> list:
    try:
        sisters = data["morsor"]["local"]["sisters"]
    except (KeyError, TypeError):
        die(f"Config file {props_file} must contain morsor.local.sisters array")
    if not isinstance(sisters, list):
        die(f"morsor.local.sisters in {props_file} must be a list")
    return sisters


def _scan_directory(path: str) -> list[str]:
    p = Path(path)
    if not p.is_dir():
        die(f"Not a directory: {path}")
    try:
        return sorted(os.listdir(p))
    except PermissionError as e:
        die(f"Cannot read directory {path}: {e}")


def _dir_content_hash(entries: list[str]) -> str:
    """SHA-256 of the sorted, newline-joined directory listing."""
    return hashlib.sha256("\n".join(sorted(entries)).encode()).hexdigest()


def _get_server_sisters(
    base: str,
    bearer: str | None,
    extra_headers: list[str],
    debug: bool,
) -> dict:
    """Fetch current sister registrations from GET /api/ephemeral-troves/sisters.

    Returns dict: trove_id -> {"ephemeralId": ..., "contentHash": ..., "registeredAt": ...}
    """
    token = bearer
    if (not token or not token.strip()) and is_likely_local_dev_base(base):
        token = DEV_DEFAULT_TOKEN
    url = strip_trailing_slash(base) + "/api/ephemeral-troves/sisters"
    headers: dict[str, str] = {}
    if token and token.strip():
        headers["Authorization"] = "Bearer " + token.strip()
    for h in extra_headers:
        if ":" not in h or h.index(":") <= 0:
            die(f"header must be Name: value, got: {h}")
        name, value = h.split(":", 1)
        headers[name.strip()] = value.strip()
    req = urllib.request.Request(url, headers=headers)
    if debug:
        print(f"[debug] GET {url}", file=sys.stderr)
    try:
        with urllib.request.urlopen(req, timeout=30) as resp:
            data = json.loads(resp.read().decode("utf-8", errors="replace"))
            return {
                item["troveId"]: {
                    "ephemeralId": item.get("ephemeralTroveId"),
                    "contentHash": item.get("contentHash"),
                    "registeredAt": item.get("registeredAt"),
                }
                for item in data
                if isinstance(item, dict) and item.get("troveId")
            }
    except HTTPError as e:
        die(f"GET /api/ephemeral-troves/sisters failed: HTTP {e.code}")
    except URLError as e:
        die(_server_unreachable(base, e))


def _delete_ephemeral_trove(
    base: str,
    bearer: str | None,
    extra_headers: list[str],
    debug: bool,
    ephemeral_id: str,
) -> None:
    token = bearer
    if (not token or not token.strip()) and is_likely_local_dev_base(base):
        token = DEV_DEFAULT_TOKEN
    url = strip_trailing_slash(base) + "/api/ephemeral-troves/" + urllib.parse.quote(ephemeral_id, safe="")
    headers: dict[str, str] = {}
    if token and token.strip():
        headers["Authorization"] = "Bearer " + token.strip()
    for h in extra_headers:
        if ":" not in h or h.index(":") <= 0:
            die(f"header must be Name: value, got: {h}")
        name, value = h.split(":", 1)
        headers[name.strip()] = value.strip()
    req = urllib.request.Request(url, method="DELETE", headers=headers)
    if debug:
        print(f"[debug] DELETE {url}", file=sys.stderr)
    try:
        with urllib.request.urlopen(req, timeout=60):
            pass
    except HTTPError as e:
        if e.code == 404:
            if debug:
                print(f"[debug] DELETE {ephemeral_id}: not found (already gone)", file=sys.stderr)
        else:
            print(f"morsor-cli: local: DELETE {ephemeral_id} failed: HTTP {e.code}", file=sys.stderr)
    except URLError as e:
        die(_server_unreachable(base, e))


def _post_sister_trove(
    base: str,
    bearer: str | None,
    extra_headers: list[str],
    debug: bool,
    display_name: str,
    items: list[dict],
    sister_trove_id: str,
    content_hash: str | None = None,
) -> dict | None:
    token = bearer
    if (not token or not token.strip()) and is_likely_local_dev_base(base):
        token = DEV_DEFAULT_TOKEN
    body_obj: dict = {
        "displayName": display_name,
        "items": items,
        "cliCreated": True,
        "sisterTroveId": sister_trove_id,
    }
    if content_hash:
        body_obj["contentHash"] = content_hash
    body_bytes = json.dumps(body_obj).encode("utf-8")
    url = strip_trailing_slash(base) + "/api/ephemeral-troves"
    headers = {"Content-Type": "application/json"}
    if token and token.strip():
        headers["Authorization"] = "Bearer " + token.strip()
    for h in extra_headers:
        if ":" not in h or h.index(":") <= 0:
            die(f"header must be Name: value, got: {h}")
        name, value = h.split(":", 1)
        headers[name.strip()] = value.strip()
    req = urllib.request.Request(url, data=body_bytes, method="POST", headers=headers)
    if debug:
        print(f"[debug] POST {url} sisterTroveId={sister_trove_id} items={len(items)}", file=sys.stderr)
    try:
        with urllib.request.urlopen(req, timeout=600) as resp:
            raw = resp.read().decode("utf-8", errors="replace")
            return json.loads(raw)
    except HTTPError as e:
        raw = e.read().decode("utf-8", errors="replace") if e.fp else ""
        print(
            f"morsor-cli: local: POST /api/ephemeral-troves for sister of \"{sister_trove_id}\" failed: HTTP {e.code}",
            file=sys.stderr,
        )
        if raw:
            print(f"  {raw[:400]}", file=sys.stderr)
        return None
    except URLError as e:
        die(_server_unreachable(base, e))


def run_local_sisters_create(
    base: str,
    bearer: str | None,
    extra_headers: list[str],
    debug: bool,
    output_mode: str,
) -> None:
    """Reconcile local sister troves from MORSOR_PROPERTIES_FILE with the server index.

    For each configured sister: delete any existing ephemeral trove for it, then
    register a fresh one from the current directory contents.
    Any ephemeral troves in the state file that are no longer in the config are also deleted.
    """
    props_file = _morsor_properties_file()
    data = _load_morsor_properties(props_file)
    sisters = _get_sisters(data, props_file)

    configured_ids: set[str] = set()
    for s in sisters:
        tid = (s.get("trove-id") or "").strip() if isinstance(s, dict) else ""
        if tid:
            configured_ids.add(tid)

    server_state = _get_server_sisters(base, bearer, extra_headers, debug)

    # Delete orphaned ephemeral troves (on server but no longer in config).
    for trove_id, entry in server_state.items():
        if trove_id not in configured_ids:
            ephemeral_id = entry.get("ephemeralId")
            if ephemeral_id:
                print(
                    f"morsor-cli: local sisters create: removing orphan {ephemeral_id}"
                    f" (sister of {trove_id!r}, no longer configured)",
                    file=sys.stderr,
                )
                _delete_ephemeral_trove(base, bearer, extra_headers, debug, ephemeral_id)

    rows: list[tuple[str, str, int, str]] = []  # trove_id, ephemeral_id, count, path

    for sister in sisters:
        if not isinstance(sister, dict):
            die(f"Each entry in morsor.local.sisters must be an object, got: {sister!r}")
        trove_id = (sister.get("trove-id") or "").strip()
        path = (sister.get("path") or "").strip()
        if not trove_id:
            die("Each sister entry must have a non-empty trove-id")
        if not path:
            die(f"Sister entry for trove-id {trove_id!r} must have a non-empty path")

        print(f"morsor-cli: local sisters create: scanning {path!r} …", file=sys.stderr)
        entries = _scan_directory(path)
        content_hash = _dir_content_hash(entries)

        existing = server_state.get(trove_id, {})
        existing_id = existing.get("ephemeralId")
        if existing_id and existing.get("contentHash") == content_hash:
            print(
                f"morsor-cli: local sisters create:   no change since last upload, skipping {trove_id!r}",
                file=sys.stderr,
            )
            continue

        if existing_id:
            print(
                f"morsor-cli: local sisters create: replacing {existing_id} for {trove_id!r}",
                file=sys.stderr,
            )
            _delete_ephemeral_trove(base, bearer, extra_headers, debug, existing_id)

        items = [{"id": str(i + 1), "title": name, "files": []} for i, name in enumerate(entries)]
        print(f"morsor-cli: local sisters create:   {len(items)} items", file=sys.stderr)

        reg = _post_sister_trove(base, bearer, extra_headers, debug, path, items, trove_id, content_hash)
        if reg is None:
            die(f"Failed to register sister trove for {trove_id!r}")

        ephemeral_id = reg.get("troveId", "")
        count = reg.get("count", len(items))
        rows.append((trove_id, ephemeral_id, count, path))
        print(
            f"morsor-cli: local sisters create:   registered {ephemeral_id} ({count} items)",
            file=sys.stderr,
        )

    if output_mode == "json":
        updated = {t: e for t, e, _, _ in rows}
        print(json.dumps(updated, indent=2))
    else:
        if rows:
            max_tid = max(len(r[0]) for r in rows)
            max_eid = max(len(r[1]) for r in rows)
            for trove_id, ephemeral_id, count, path in rows:
                print(f"{pad_right(trove_id, max_tid)}\t{pad_right(ephemeral_id, max_eid)}\t{count}\t{path}")


def run_local_sisters_list(
    base: str,
    bearer: str | None,
    extra_headers: list[str],
    debug: bool,
    output_mode: str,
) -> None:
    """Print all configured sisters with upload status. Troves not in config are not shown."""
    props_file = _morsor_properties_file()
    data = _load_morsor_properties(props_file)
    sisters = _get_sisters(data, props_file)
    server_state = _get_server_sisters(base, bearer, extra_headers, debug)

    rows = []
    for s in sisters:
        if not isinstance(s, dict):
            continue
        trove_id = (s.get("trove-id") or "").strip()
        path = (s.get("path") or "").strip()
        if not trove_id:
            continue
        entry = server_state.get(trove_id, {})
        ephemeral_id = entry.get("ephemeralId") or "-"
        registered_at = entry.get("registeredAt")
        if not entry:
            status = "Not Uploaded"
        elif registered_at:
            status = f"Uploaded on {registered_at}"
        else:
            status = "Uploaded"
        rows.append((trove_id, path, ephemeral_id, status))

    if not rows:
        return

    if output_mode == "json":
        print(json.dumps(
            [
                {"troveId": t, "path": p, "ephemeralId": e if e != "-" else None, "status": s}
                for t, p, e, s in rows
            ],
            indent=2,
        ))
    else:
        max_tid = max(len(r[0]) for r in rows)
        max_path = max(len(r[1]) for r in rows)
        max_eid = max(len(r[2]) for r in rows)
        for trove_id, path, ephemeral_id, status in rows:
            print(f"{pad_right(trove_id, max_tid)}\t{pad_right(path, max_path)}\t{pad_right(ephemeral_id, max_eid)}\t{status}")


def run_local_sisters_clear(
    base: str,
    bearer: str | None,
    extra_headers: list[str],
    debug: bool,
) -> None:
    """Delete all ephemeral sister troves currently registered on the server."""
    server_state = _get_server_sisters(base, bearer, extra_headers, debug)
    if not server_state:
        print("morsor-cli: local sisters clear: nothing to clear", file=sys.stderr)
        return
    for trove_id, entry in server_state.items():
        ephemeral_id = entry.get("ephemeralId")
        if ephemeral_id:
            print(f"morsor-cli: local sisters clear: deleting {ephemeral_id} (sister of {trove_id!r})", file=sys.stderr)
            _delete_ephemeral_trove(base, bearer, extra_headers, debug, ephemeral_id)
    print("morsor-cli: local sisters clear: done", file=sys.stderr)


def run_local_command(
    args: list[str],
    base: str,
    bearer: str | None,
    extra_headers: list[str],
    debug: bool,
    output_mode: str,
) -> None:
    if not args:
        die("local requires a subcommand: sisters")
    subcommand = args[0].lower()
    if subcommand == "sisters":
        if len(args) < 2:
            die("local sisters requires a subcommand: create, list, clear")
        sub = args[1].lower()
        if sub == "create":
            run_local_sisters_create(base, bearer, extra_headers, debug, output_mode)
        elif sub == "list":
            run_local_sisters_list(base, bearer, extra_headers, debug, output_mode)
        elif sub == "clear":
            run_local_sisters_clear(base, bearer, extra_headers, debug)
        else:
            die(f"unknown subcommand: local sisters {sub!r}  (expected: create, list, clear)")
    else:
        die(f"unknown local subcommand: {subcommand!r}  (expected: sisters)")


MORSOR_CLI_MAN_PAGE = """
MORSOR-CLI(1)                    User Commands                    MORSOR-CLI(1)

NAME
       morsor-cli — HTTP client for the Morsor search API

REQUIREMENTS

       Python 3 stdlib only

SYNOPSIS
       morsor-cli [--help | --man]

       morsor-cli [OPTIONS] login

       morsor-cli [OPTIONS] [<action>] [--key value | -k value | --key=value ...]
                  [query text...]

    morsor-cli [OPTIONS] local-trove [FILE]
    morsor-cli [OPTIONS] register-local-dir [FILE]

       morsor-cli [OPTIONS] METHOD PATH [-- querystring]

DESCRIPTION
       morsor-cli calls the backend under -b/--base (default http://localhost:8080).
       Set MORSOR_CLI_BASE_URL to override the default base URL.

       Authenticated servers: use login (session cookie jar) or -T/--token with a
       Bearer API token.

THREE WAYS TO SEARCH
       The backend exposes three related operations; pick the matching action:

       search (default)
              Full-text search over one or more troves (lists). Use --trove (repeat
              or comma-separated via -t) to restrict troves; optional --query; page
              with -P/--page and -S/--size/--pageSize. Hits are ranked matches across
              the selected troves.

       dups, duplicates
              Cross-trove duplicate (near-duplicate) analysis. Requires
              --primaryTrove / -p: items in that trove are matched against one or
              more --compareTrove / -c values. Optional query narrows primary items.
              Pagination: -P, -S (server caps duplicates/uniques page size at 500).

       uniques, unique
              Converse of duplicates: items in the primary trove that have no good
              match in the compare troves, for the optional query. Same primary/
              compare parameters as duplicates (same 500 cap on page size).

LOCAL SISTER TROVES (DIRECTORY SCAN)
       local sisters create

                   Reconciles the server index with the directories listed in
                   MORSOR_PROPERTIES_FILE (a YAML or JSON config file).  For
                   each configured sister: any existing ephemeral trove for
                   that sister is deleted and a fresh one is registered from
                   the current directory contents (one item per file/directory
                   found one level deep).  Ephemeral troves in the saved state
                   that are no longer in the config are also deleted (orphan
                   cleanup).  Safe to run repeatedly — always produces a clean,
                   up-to-date result.

                   After create, any search on a configured non-ephemeral trove
                   automatically includes its local sister's results, and the
                   API response includes a "caveats" field noting the expansion.

       local sisters list

                   Prints all configured sisters with their upload status
                   (Not Uploaded / Uploaded on <timestamp>), ephemeral trove
                   ID, and directory path.  Queries the server for live state.
                   Troves not in the config are not shown.

       local sisters clear

                   Deletes every ephemeral trove recorded in the state file
                   and resets the state.  Subsequent searches on the
                   non-ephemeral troves will no longer include local sisters
                   until the next create.

       Config is read from the file pointed to by MORSOR_PROPERTIES_FILE:

           morsor:
             local:
               sisters:
               - trove-id: synology-series
                 path: "/path/to/series/directory"

       Supports JSON (.json) natively; YAML requires PyYAML (pip install pyyaml).

       A state file is written alongside the config file (same stem, extension
       .state.json) so that the next create knows which ephemeral IDs to replace.

EPHEMERAL TROVES (LINE INPUT)
    local-trove (alias register-local-dir) reads item titles one-per-line from
    FILE, or from stdin when FILE is omitted. It POSTs those items to the
    server as an ephemeral trove, and prints the assigned trove id and display
    name.

       • Trove id is always server-generated: local-<uuid> (you do not choose it).
    • Display name is FILE’s absolute path, or "stdin" when reading from stdin.
       • Ephemeral troves are merged into the index with persisted troves and
         survive reload of trove data on the server; they are in-memory and are
         lost on JVM restart. DELETE /api/ephemeral-troves/{id} removes one by id.

       Use the printed trove id like any other trove: search --trove=local-...,
       dups -p local-... -c some-other-trove, etc.

OPTIONS
       -b, --base URL
              API base (no trailing slash). Default: http://localhost:8080 unless
              MORSOR_CLI_BASE_URL is set.

       -T, --token TOKEN
              Send Authorization: Bearer TOKEN (omit for cookie-only login flow).

       -o, --output json|text
              json: raw response body. text: abbreviated tables/lines for search,
              troves, duplicates, uniques.

       -H, --header 'Name: value'
              Extra request header (repeatable).

       -F, --file PATH
              POST body from file (only with POST).

    --name NAME
        local-trove only: override generated display name for the uploaded
        ephemeral trove.

       -i, --include-headers
              Print response status and headers before the body.

       -v, --debug
              Log request URL and headers on stderr.

ENVIRONMENT
       MORSOR_CLI_BASE_URL     Default base URL (-b overrides).
       MORSOR_PROPERTIES_FILE  Path to YAML/JSON config for local init/refresh.

ACTIONS
       search       GET /api/search (default if the first token is not an action)
       dups         GET /api/search/duplicates
       duplicates   same as dups
       uniques      GET /api/search/uniques
       unique       same as uniques
       troves       GET /api/troves
       status       GET /api/status
    local sisters create  Reconcile sister troves from config (see above).
    local sisters list    List troves that have a registered local sister.
    local sisters clear   Delete all ephemeral sister troves and clear state.
    local-trove  Register line input as an ephemeral trove (see above).
              Accepts optional --name NAME.
       login        Obtain session cookie (no -T/-H)

SHORTHAND PARAMETERS (after an action)
       Keys are normalized for convenience, e.g. -p → primaryTrove, -c →
       compareTrove, -t/--trove → trove (repeatable). Use -- query after METHOD
       PATH for raw key=value pairs.

       q, query          Search query string (naked words append to query)
       p, primary        primaryTrove (duplicates/uniques)
       c, compare        compareTrove (repeat; multiple compare troves)
       t, trove          trove constraint (search); comma-separated ok
       P, page           page (0-based)
       S, size, pageSize size (page length)
       s, sortBy         sort field
       d, sortDir        sort direction

RAW HTTP
       morsor-cli GET /api/search -- query=*&page=0&size=10

       After --, each argument must be key=value; joined with & for the query string.

EXAMPLES
       List all troves:

              ./scripts/morsor-cli troves

       Search the vinyl trove for artists matching “King Gizzard”:

              ./scripts/morsor-cli search --trove=vinyl --query='King Gizzard'

    Reconcile local sister troves from config (MORSOR_PROPERTIES_FILE must be set):

        MORSOR_PROPERTIES_FILE=~/.morsor.yaml ./scripts/morsor-cli local sisters create

    Register from a file (one title per line):

        ./scripts/morsor-cli local-trove /path/to/titles.txt

    Register from stdin:

        cat /path/to/titles.txt | ./scripts/morsor-cli local-trove

    Override the generated trove name:

        ./scripts/morsor-cli local-trove --name "My Temp List" /path/to/titles.txt

       Duplicates: primary is ephemeral local trove; compare against vinyl and CDs;
       large page; JSON to jq (titles of primary rows):

              ./scripts/morsor-cli dups -S 10000 \\
                --primaryTrove=local-e980f196-ae1c-4c82-9f9f-a3e5b8e06920 \\
                --compareTrove=vinyl --compareTrove=CDs -o json \\
                | jq -r '.rows[].primary.title'

       Verbose raw search request:

              ./scripts/morsor-cli -v -b http://localhost:8080 GET /api/search -- \\
                query=*&page=0&size=10

SEE ALSO
       https://github.com/cschuyle/morsor

""".strip()


def print_summary_usage() -> None:
    print(
        """
USAGE SUMMARY

  morsor-cli --help      # This message
  morsor-cli --man       # Full manual (man-page style; use with a pager)

  morsor-cli [OPTIONS] login
  morsor-cli [OPTIONS] [<action>] [--<key> <value> ...] [query text]

ACTIONS
  search (default)   dups | duplicates   uniques | unique   troves   status
  local sisters create | list | clear
    local-trove [FILE] register-local-dir [FILE]

ENV: MORSOR_CLI_BASE_URL sets default base if -b/--base is not provided
     MORSOR_PROPERTIES_FILE required for local init/refresh

Examples:
  morsor-cli search --trove=vinyl --query='*'
  morsor-cli local sisters create
    morsor-cli local-trove /path/to/titles.txt
    cat /path/to/titles.txt | morsor-cli local-trove
  morsor-cli -v -b http://localhost:8080 GET /api/search -- query=*&page=0&size=10
""".strip()
    )


def print_usage() -> None:
    """Long-form manual (stdout) so: morsor-cli --man | less"""
    print(MORSOR_CLI_MAN_PAGE)


def main(argv: list[str]) -> None:
    if not argv:
        print_summary_usage()
        sys.exit(0)
    extra_headers: list[str] = []
    base = "http://localhost:8080"
    base_set_by_arg = False
    bearer: str | None = None
    body_file: str | None = None
    local_trove_name_override: str | None = None
    output_mode = "text"
    show_headers = False
    debug = False
    positional: list[str] = []
    i = 0
    while i < len(argv):
        a = argv[i]
        if a == "--man":
            print_usage()
            sys.exit(0)
        if a in ("-h", "--help", "help"):
            print_summary_usage()
            sys.exit(0)
        if a in ("-b", "--base"):
            i += 1
            if i >= len(argv):
                die(f"missing value for {argv[i - 1]}")
            base = strip_trailing_slash(argv[i])
            base_set_by_arg = True
        elif a in ("-T", "--token"):
            i += 1
            if i >= len(argv):
                die(f"missing value for {argv[i - 1]}")
            bearer = argv[i]
        elif a in ("-H", "--header"):
            i += 1
            if i >= len(argv):
                die(f"missing value for {argv[i - 1]}")
            extra_headers.append(argv[i])
        elif a in ("-F", "--file"):
            i += 1
            if i >= len(argv):
                die(f"missing value for {argv[i - 1]}")
            body_file = argv[i]
        elif a == "--name":
            i += 1
            if i >= len(argv):
                die("missing value for --name")
            val = argv[i].strip()
            if not val:
                die("--name requires a non-empty value")
            local_trove_name_override = val
        elif a.startswith("--name="):
            val = a.split("=", 1)[1].strip()
            if not val:
                die("--name requires a non-empty value")
            local_trove_name_override = val
        elif a in ("-o", "--output"):
            i += 1
            if i >= len(argv):
                die(f"missing value for {argv[i - 1]}")
            output_mode = normalize_output_mode(argv[i])
        elif a in ("-i", "--include-headers"):
            show_headers = True
        elif a in ("-v", "--debug"):
            debug = True
        elif a == "--":
            positional.append(a)
            i += 1
            while i < len(argv):
                positional.append(argv[i])
                i += 1
            break
        else:
            positional.append(a)
        i += 1

    if not positional:
        print_summary_usage()
        sys.exit(0)

    env_base = os.environ.get("MORSOR_CLI_BASE_URL")
    if (not base_set_by_arg) and env_base and env_base.strip():
        base = strip_trailing_slash(env_base.strip())

    if is_local_command(positional[0]):
        if body_file:
            die("--file is not valid with local")
        if local_trove_name_override is not None:
            die("--name is not valid with local")
        run_local_command(positional[1:], base, bearer, extra_headers, debug, output_mode)
        return

    if is_local_trove_action(positional[0]):
        if body_file:
            die("--file is not valid with local-trove")
        run_local_trove(
            base,
            bearer,
            extra_headers,
            show_headers,
            debug,
            output_mode,
            positional,
            local_trove_name_override,
        )
        return

    if local_trove_name_override is not None:
        die("--name is only valid with local-trove")

    if positional[0].lower() == "login":
        if len(positional) > 1:
            die("login takes no arguments (use -b for base URL)")
        if body_file:
            die("--file is not valid with login")
        if bearer:
            die("--token is not valid with login")
        if extra_headers:
            die("-H is not valid with login")
        if show_headers:
            die("-i is not valid with login")
        run_login(base)
        return

    idx = 0
    first = positional[idx]
    if is_http_method(first):
        method = first.upper()
        idx += 1
        if idx >= len(positional):
            die("missing path")
        path = positional[idx]
        idx += 1
        if path.startswith("http://") or path.startswith("https://"):
            die("path must be relative (e.g. /api/status), not a full URL")
        if not path.startswith("/"):
            path = "/" + path
        query = ""
        if idx < len(positional):
            if positional[idx] != "--":
                die("unexpected arguments after path (use -- for query string)")
            idx += 1
            query = "&".join(positional[idx:])
    else:
        spec = resolve_action(first)
        if spec:
            method, path = spec
            idx += 1
        else:
            method = "GET"
            path = "/api/search"
        query = parse_shorthand_query(positional, idx)

    if body_file and method != "POST":
        die("--file is only valid for POST")

    http_request(
        base,
        method,
        path,
        query,
        bearer,
        extra_headers,
        body_file,
        show_headers,
        debug,
        output_mode,
    )


if __name__ == "__main__":
    main(sys.argv[1:])
