#!/usr/bin/env bash
set -euo pipefail
# HTTP CLI for the Morsor backend (shells out to java -jar). See: tools/morsor-api-cli
ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT"
JAR="$ROOT/tools/morsor-api-cli/build/libs/morsor-api-cli-0.0.1-SNAPSHOT.jar"
echo Looking for $JAR... 
if [[ ! -f "$JAR" ]]; then
  echo "Building morsor-api-cli..."
  ./gradlew :morsor-api-cli:jar -q
fi
echo "Running morsor-api-cli..."
exec java -jar "$JAR" "$@"
