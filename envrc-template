# The app will run out of the box using the canned data. All configuration variables are optional.

# For production: postgres = Postgres, no dev seeding; s3troves = trove data from S3. Use both for postgres + S3.
export SPRING_PROFILES_ACTIVE=postgres,s3troves

export AWS_ACCESS_KEY_ID=...
export AWS_SECRET_ACCESS_KEY=...
export AWS_REGION=...

# This is the bucket where the troves are stored. See DATA.md for more details.
export MOOCHO_BUCKET_NAME=blah

# When not using S3, trove JSON is loaded from this location (dev/default). Default is file:./fixtures/data/*.json when run from project root. Use to point at a different directory or classpath, e.g. classpath*:data/*.json.
#export MOOCHO_DATA_LOCATION=file:./fixtures/data/*.json

# Use this to only load a subset of troves. 
# This can be useful if you have a LOT of data and you want to startup quicker, or have limited compute resources. 
# This is especially important because the implementation uses embedded (in-memory) Lucene (search engine). 
# All data is loaded and indexed at startup time.
#export MOOCHO_ONLY_TROVE_IDS=trove-id-1,trove-id-2,...

# Search/duplicates/uniques result cache: TTL in minutes (default 720 = 12h), max memory in bytes (default 1073741824 = 1GB).
# When the cache is full, new results are still returned but not cached; the UI shows a warning.
#export MOOCHO_CACHE_TTL_MINUTES=720
#export MOOCHO_CACHE_MAX_BYTES=1073741824

# Login session timeout (Spring Boot duration; default 12h).
# Example values: 30m, 12h, 1d
#export MOOCHO_SESSION_TIMEOUT=12h
